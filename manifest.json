{
  "manifest_version": 3,
  "name": "Comment Filtter",
  "version": "1.0",
  "description": "Simple Comment Filter for YouTube",
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ],
  "permissions": ["storage"]
}
